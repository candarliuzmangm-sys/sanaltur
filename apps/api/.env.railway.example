# Railway Variables sekmesine yapistirin (token buraya YAZMAYIN)
NODE_ENV=production
PORT=3001

JWT_SECRET=uzun-rastgele-gizli-anahtar
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Railway Postgres / Redis plugin referanslari otomatik eklenir:
# DATABASE_URL=
# REDIS_URL=

STORAGE_MODE=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sanaltur-media
R2_PUBLIC_URL=https://pub-xxxx.r2.dev

# Deploy sonrasi Railway domain ile guncelleyin:
API_PUBLIC_URL=https://YOUR-PROJECT.up.railway.app
PUBLIC_WEB_URL=https://YOUR-PROJECT.up.railway.app

AI_SERVICE_URL=http://127.0.0.1:8000
