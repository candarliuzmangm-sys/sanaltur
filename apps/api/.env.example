NODE_ENV=development
PORT=3001

DATABASE_URL=postgresql://sanaltur:sanaltur_dev@localhost:5432/sanaltur
REDIS_URL=redis://localhost:6379

JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

AI_SERVICE_URL=http://localhost:8000

# Storage: local (dev) | r2 (production)
STORAGE_MODE=local
# Telefon icin: .\scripts\sync-lan-env.ps1 ile otomatik LAN IP yazar
API_PUBLIC_URL=http://localhost:3001

# Cloudflare R2 (S3-compatible) — only when STORAGE_MODE=r2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=sanaltur-media
R2_PUBLIC_URL=https://media.sanaltur.com

PUBLIC_WEB_URL=http://localhost:3000
